        {
          "name": "Sign Up - invalid mobile number",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ─── Status Code ───────────────────────────────────────────────",
                  "pm.test(\"Status code is 422 Unprocessable Entity\", function () {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "",
                  "// ─── Content-Type ──────────────────────────────────────────────",
                  "pm.test(\"Content-Type is application/json\", function () {",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
                  "});",
                  "",
                  "// ─── Detail Array Exists ───────────────────────────────────────",
                  "",
                  "const response = pm.response.json();",
                  "pm.test(\"Response contains a detail array\", function () {",
                  "    pm.expect(response).to.have.property(\"detail\");",
                  "    pm.expect(response.detail).to.be.an(\"array\");",
                  "    pm.expect(response.detail).to.have.length.above(0);",
                  "});",
                  "",
                  "// ─── Error Points to Phone Field ──────────────────────────────",
                  "pm.test(\"Error location points to phone field\", function () {",
                  "    const error = response.detail[0];",
                  "    pm.expect(error.loc).to.include(\"phone\");",
                  "});",
                  "",
                  "// ─── Error Type ────────────────────────────────────────────────",
                  "pm.test(\"Error type is value_error\", function () {",
                  "    const error = response.detail[0];",
                  "    pm.expect(error.type).to.eql(\"value_error\");",
                  "});",
                  "",
                  "",
                  "// ─── No User Created ───────────────────────────────────────────",
                  "pm.test(\"No user data is returned on validation failure\", function () {",
                  "    pm.expect(response).to.not.have.property(\"userID\");",
                  "    pm.expect(response).to.not.have.property(\"token\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
