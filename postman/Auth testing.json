    {
      "name": "Authentication Tests",
      "item": [
        {
          "name": "Sign Up - normal path (coach)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ─── Status Code ───────────────────────────────────────────────",
                  "pm.test(\"Status code is 200 Created\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// ─── Content-Type ──────────────────────────────────────────────",
                  "",
                  "pm.test(\"Content-Type is application/json\", function () {",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
                  "});",
                  "",
                  "",
                  "// ─── Body Structure ────────────────────────────────────────────",
                  "",
                  "const response = pm.response.json();",
                  "pm.test(\"Response body has required fields\", function () {",
                  "    pm.expect(response).to.be.an(\"object\");",
                  "    pm.expect(response).to.have.property(\"userID\");",
                  "    pm.expect(response).to.have.property(\"name\");",
                  "    pm.expect(response).to.have.property(\"email\");",
                  "    pm.expect(response).to.have.property(\"phone\");",
                  "    pm.expect(response).to.have.property(\"role\");",
                  "});",
                  "",
                  "// // ─── Field Values Match Request ────────────────────────────────",
                  "pm.test(\"Returned user data matches the role\", function () {",
                  "    pm.expect(response.role).to.eql(\"coach\");",
                  "});",
                  "",
                  "// ─── Password Not Exposed ──────────────────────────────────────",
                  "pm.test(\"Password is not returned in response\", function () {",
                  "    pm.expect(response).to.not.have.property(\"password\");",
                  "});",
                  "",
                  "// ─── ID is valid ───────────────────────────────────────────────",
                  "pm.test(\"User ID is present and non-empty\", function () {",
                  "    pm.expect(response.userID).to.exist;",
                  "    pm.expect(response.userID).to.be.a(\"number\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"coach name\",\n  \"email\": \"coach@gym.com\",\n  \"phone\": \"01000000000\",\n  \"password\": \"12345678\",\n  \"role\": \"coach\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/signup",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            }
          },
          "response": []
        },
